// 1. Import your shared library for notifications
@Library('shared-library') _

node {
    def securityReportName = 'coverage/lcov-report/index.html' 
    
    try {
        stage('Checkout') {
            checkout scm
        }

        stage('Build & Test') {
            // 2. Request the Global Tool by the exact name configured in the Jenkins UI
            def nodeHome = tool name: 'NodeJS 20', type: 'jenkins.plugins.nodejs.tools.NodeJSInstallation'
            
            // 3. Inject the tool's bin folder into the PATH, alongside CI=true
            withEnv(["PATH+NODE=${nodeHome}/bin", 'CI=true']) {
                sh '''
                echo "1. Verifying Jenkins Global Tool Node Version:"
                node -v
                
                echo "2. Installing Dependencies..."
                npm install
                
                echo "3. Executing Unit Tests..."
                npm run test -- --coverage
                '''
            }
        }
        
        stage('Save Artifacts') {
            archiveArtifacts artifacts: 'coverage/**', allowEmptyArchive: true
        }
        
    } catch (Exception e) {
        currentBuild.result = 'FAILURE'
        throw e 
    } finally {
        notifyTeam(currentBuild.currentResult ?: 'SUCCESS', [
            projectModule: 'Salary & Attendance Management System',
            slackChannel: '#jenkins-alerts',
            teamEmail: '3dnagar@gmail.com',
            jenkinsUrl: 'http://jenkins.local:9090',
            reportArtifact: securityReportName
        ])
    }
}
