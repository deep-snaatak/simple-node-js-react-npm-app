// 1. Import your shared library for enterprise notifications
@Library('shared-library') _

node {
    // Define the path to the coverage report that Vitest will generate
    def securityReportName = 'coverage/index.html' 
    
    try {
        stage('Checkout') {
            // Pulls the code from your currently configured Git branch
            checkout scm
        }

        stage('Build & Test') {
            // Request the Global Tool exactly as you named it in the Jenkins UI
            def nodeHome = tool name: 'NodeJS 20', type: 'jenkins.plugins.nodejs.tools.NodeJSInstallation'
            
            // Inject Node 20 into the PATH and set CI=true to prevent hanging
            withEnv(["PATH+NODE=${nodeHome}/bin", 'CI=true']) {
                sh '''
                echo "1. Verifying Jenkins Global Tool Node Version:"
                node -v
                
                echo "2. Installing Project Dependencies..."
                npm install
                
                echo "3. Fixing missing Vitest coverage dependency on the fly..."
                npm install --save-dev @vitest/coverage-v8
                
                echo "4. Executing Unit Tests with Dual Reporting & Quality Gates..."
                # --reporter=default outputs text to console
                # --reporter=junit outputs functional pass/fail data to junit.xml
                # --coverage.thresholds enforce the 80% minimum quality rule
                npm run test -- --coverage \
                  --reporter=default \
                  --reporter=junit \
                  --outputFile=junit.xml \
                  --coverage.thresholds.statements=80 \
                  --coverage.thresholds.branches=80 \
                  --coverage.thresholds.functions=80 \
                  --coverage.thresholds.lines=80
                '''
            }
        }
        
        stage('Save Artifacts') {
            // Save the visual coverage dashboard folder to the Jenkins server
            archiveArtifacts artifacts: 'coverage/**', allowEmptyArchive: true
            
            // Publish the functional pass/fail test report directly onto the Jenkins UI dashboard
            junit testResults: 'junit.xml', allowEmptyResults: true
        }
        
    } catch (Exception e) {
        // If any stage fails (broken test or low coverage), mark the build as failed
        currentBuild.result = 'FAILURE'
        throw e 
    } finally {
        // Always send the notification alert, regardless of pass or fail
        notifyTeam(currentBuild.currentResult ?: 'SUCCESS', [
            projectModule: 'Salary & Attendance Management System',
            slackChannel: '#jenkins-alerts',
            teamEmail: '3dnagar@gmail.com',
            jenkinsUrl: 'http://jenkins.local:9090',
            reportArtifact: securityReportName
        ])
    }
}
