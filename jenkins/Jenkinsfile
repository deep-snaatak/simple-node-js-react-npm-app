// 1. Import your shared library for notifications
@Library('shared-library') _

node {
    // Define the path to the React coverage report Jest generates
    def securityReportName = 'coverage/lcov-report/index.html' 
    
    try {
        stage('Checkout') {
            // Pulls the code from your currently configured Git branch
            checkout scm
        }

        stage('Install Dependencies') {
            sh 'npm install'
        }

        stage('Unit Testing') {
            // CI=true prevents Jest from hanging in interactive watch mode.
            // We removed the openssl flag because your Jenkins runs Node v16.
            withEnv(['CI=true']) {
                // The --coverage flag creates the 'coverage/' folder
                sh 'npm run test -- --coverage'
            }
        }
        
        stage('Save Artifacts') {
            // This saves the report to the Jenkins server so your team can view it 
            // when they click the link in the email or Slack alert.
            archiveArtifacts artifacts: 'coverage/**', allowEmptyArchive: true
        }
        
    } catch (Exception e) {
        // If any stage above fails (like a broken test), mark the build as failed
        currentBuild.result = 'FAILURE'
        throw e 
    } finally {
        // This 'finally' block acts exactly like 'post { always { ... } }'.
        // It guarantees the notification is sent whether the pipeline passed or failed.
        
        notifyTeam(currentBuild.currentResult ?: 'SUCCESS', [
            projectModule: 'Salary & Attendance Management System',
            slackChannel: '#jenkins-alerts',
            teamEmail: '3dnagar@gmail.com',
            jenkinsUrl: 'http://jenkins.local:9090',
            reportArtifact: securityReportName
        ])
    }
}
