// 1. Import your shared library for enterprise notifications
@Library('shared-library') _

node {
    // Define the path to the coverage report that Vitest will generate
    def securityReportName = 'coverage/index.html'
    
    try {
        stage('Checkout') {
            // Pulls the code from your currently configured Git branch
            checkout scm
        }

        stage('Build & Test') {
            // 2. Request the Global Tool exactly as you named it in the Jenkins UI
            def nodeHome = tool name: 'NodeJS 20', type: 'jenkins.plugins.nodejs.tools.NodeJSInstallation'
            
            // 3. Inject Node 20 into the PATH and set CI=true to prevent hanging
            withEnv(["PATH+NODE=${nodeHome}/bin", 'CI=true']) {
                sh '''
                echo "1. Verifying Jenkins Global Tool Node Version:"
                node -v
                
                echo "2. Installing Project Dependencies..."
                npm install
                
                echo "3. Fixing missing Vitest coverage dependency on the fly..."
                npm install --save-dev @vitest/coverage-v8
                
                echo "4. Executing Unit Tests..."
                npm run test -- --coverage
                '''
            }
        }
        
        stage('Save Artifacts') {
            // 4. Save the coverage report to the Jenkins server so the email link works
            archiveArtifacts artifacts: 'coverage/**', allowEmptyArchive: true
        }
        
    } catch (Exception e) {
        // If any stage fails, explicitly mark the build as a failure
        currentBuild.result = 'FAILURE'
        throw e 
    } finally {
        // 5. Always send the notification alert, regardless of pass or fail
        notifyTeam(currentBuild.currentResult ?: 'SUCCESS', [
            projectModule: 'Salary & Attendance Management System',
            slackChannel: '#jenkins-alerts',
            teamEmail: '3dnagar@gmail.com',
            jenkinsUrl: 'http://jenkins.local:9090',
            reportArtifact: securityReportName
        ])
    }
}
